# === Clerk (auth) ===
# clerk.com -> tu app -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Rutas de Clerk (dejar así)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# === Supabase (solo base de datos) ===
# Supabase -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key: SOLO servidor. Nunca exponer al cliente ni commitear real.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# === Seed del admin (usado por: npm run seed) ===
# Debe coincidir con el email con el que te registraste en Clerk.
SEED_ADMIN_EMAIL=admin@tudominio.com
